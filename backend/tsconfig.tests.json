{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "server-only": [
        "./tests/server-only.ts"
      ]
    }
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.json",
    "lib/**/*.js",
    "components/**/*.js",
    "app/**/*.js"
  ]
}
